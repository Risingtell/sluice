{
  "name": "sluice",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Streaming x402 meter for the agent economy — pay per second, settled on-chain via Casper.",
  "scripts": {
    "server": "tsx watch server/src/index.ts",
    "server:once": "tsx server/src/index.ts",
    "start": "tsx server/src/index.ts",
    "agent": "tsx agent/src/index.ts",
    "verify": "tsx scripts/verify-onchain.ts",
    "demo": "concurrently -k -n server,agent -c green,cyan \"npm:server:once\" \"node -e 'setTimeout(()=>{},1500)' && sleep 2 && npm:agent\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@make-software/casper-x402": "^1.0.0",
    "@x402/core": "^2.16.0",
    "@x402/express": "^2.16.0",
    "@x402/fetch": "^2.16.0",
    "casper-js-sdk": "^5.0.12",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2"
  }
}
