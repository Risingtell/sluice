# ── Sluice configuration ──────────────────────────────────────────────────────
# MOCK mode needs NOTHING set: copy to .env and run. LIVE mode needs the owner creds below.

# mock | live
MODE=mock
PORT=4021

# Hard cap on seconds billed per tick (clock-jump guard).
MAX_TICK_SECONDS=10

# ── LIVE mode only (Casper x402) ──────────────────────────────────────────────
# 1) Facilitator API key from cspr.cloud (Casper Buildathon sponsors free usage).
FACILITATOR_URL=https://x402-facilitator.cspr.cloud
FACILITATOR_API_KEY=

# 2) CAIP-2 network + payee (your funded Casper testnet account public key).
CAIP2_CHAIN_ID=casper:casper-test
PAYEE_ADDRESS=

# 3) CEP-18 token payments settle in (e.g. WCSPR package hash) + display name.
ASSET_PACKAGE=
ASSET_NAME=WCSPR

# ── Demo console (/demo.html) ─────────────────────────────────────────────────
# Live on-chain demo sessions allowed per UTC day (facilitator quota is shared).
DEMO_LIVE_SESSIONS_PER_DAY=8
DEMO_TICK_MS=2000
DEMO_MAX_TICKS=6
DEMO_BUDGET_X402=0.05
# Cloud hosts only: paste the agent PEM so the server can materialize keys/agent.pem.
# AGENT_KEY_PEM=

# ── Agent (client) ────────────────────────────────────────────────────────────
SERVER_URL=http://localhost:4021
AGENT_STREAM=btc-usd
AGENT_TICK_MS=1000
AGENT_MAX_TICKS=20
# LIVE mode: PEM-encoded ed25519 private key for the agent's Casper account.
CLIENT_PRIVATE_KEY_PATH=
CLIENT_KEY_ALGO=ed25519
